 *
 * Dongle overlay — no physical keys on this device.
 * The dongle is the split central: it receives key events from
 * totem_left and totem_right over BLE and forwards them to the
 * host via USB HID.
 *
 * We still need the full matrix transform so ZMK knows the key
 * count when compiling the keymap, but kscan is replaced with a
 * mock that never fires.
 */

#include <dt-bindings/zmk/matrix_transform.h>

/ {
    chosen {
        zmk,kscan = &mock_kscan;
        zmk,matrix_transform = &default_transform;
    };

    /*
     * Matrix transform must be identical to totem.dtsi so that the
     * keymap positions match what the peripherals report.
     */
    default_transform: keymap_transform_0 {
        compatible = "zmk,matrix-transform";
        columns = <10>;
        rows = <4>;

        map = <
            RC(0,0) RC(0,1) RC(0,2) RC(0,3) RC(0,4)     RC(0,5) RC(0,6) RC(0,7) RC(0,8) RC(0,9)
            RC(1,0) RC(1,1) RC(1,2) RC(1,3) RC(1,4)     RC(1,5) RC(1,6) RC(1,7) RC(1,8) RC(1,9)
RC(3,0) RC(2,0) RC(2,1) RC(2,2) RC(2,3) RC(2,4)     RC(2,5) RC(2,6) RC(2,7) RC(2,8) RC(2,9) RC(3,9)
                        RC(3,2) RC(3,3) RC(3,4)     RC(3,5) RC(3,6) RC(3,7)
        >;
    };

    mock_kscan: mock_kscan_0 {
        compatible = "zmk,kscan-mock";
        columns = <0>;
        rows = <0>;
        events = <0>;
    };
};
